<Page x:Class="pract15_trpo.Pages.CategoryForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract15_trpo.Pages"
      xmlns:validators="clr-namespace:pract15_trpo.Validators"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="CategoryForm">

    <Grid>
        <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Click="GoBack">Назад</Button>
        <StackPanel x:Name="Form" Grid.Column="0" HorizontalAlignment="Center" VerticalAlignment="Center" Width="300">
            <Label x:Name="Label" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center">Новая категория</Label>
            <TextBlock>Название</TextBlock>
            <TextBox x:Name="NameTextBox">
                <Binding Path="Name" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <Button Margin="5" Click="Add">Сохранить</Button>
        </StackPanel>
    </Grid>
</Page>
