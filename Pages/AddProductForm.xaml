<Page x:Class="pract15_trpo.Pages.AddProductForm"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract15_trpo.Pages"
      xmlns:validators="clr-namespace:pract15_trpo.Validators"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Форма товара">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Button HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5" Grid.Row="0" Grid.Column="0" Click="GoBack">Назад</Button>
        <StackPanel Grid.RowSpan="2" HorizontalAlignment="Center" VerticalAlignment="Center" Width="250">
            <Label x:Name="Label" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center">Новый товар</Label>
            <TextBlock>Название</TextBlock>
            <TextBox x:Name="NameTextBox">
                <Binding Path="product.Name" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:StringValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <TextBlock>Описание</TextBlock>
            <TextBox x:Name="DescriptionTextBox">
                <Binding Path="product.Description" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:TextValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <TextBlock>Цена</TextBlock>
            <TextBox x:Name="PriceTextBox">
                <Binding Path="product.Price" UpdateSourceTrigger="PropertyChanged" ConverterCulture="ru-RU">
                    <Binding.ValidationRules>
                        <validators:PriceValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <TextBlock>Количество</TextBlock>
            <TextBox x:Name="StockTextBox">
                <Binding Path="product.Stock" UpdateSourceTrigger="PropertyChanged">
                    <Binding.ValidationRules>
                        <validators:IntValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <TextBlock>Рейтинг</TextBlock>
            <TextBox x:Name="RatingTextBox">
                <Binding Path="product.Rating" UpdateSourceTrigger="LostFocus" ConverterCulture="ru-RU">
                    <Binding.ValidationRules>
                        <validators:RatingValidation/>
                    </Binding.ValidationRules>
                </Binding>
            </TextBox>
            <TextBlock>Категория</TextBlock>
            <ComboBox SelectedItem="{Binding product.Category}" ItemsSource="{Binding categoryList}" DisplayMemberPath="Name"></ComboBox>
            <TextBlock>Бренд</TextBlock>
            <ComboBox SelectedItem="{Binding product.Brand}" ItemsSource="{Binding brandList}" DisplayMemberPath="Name"></ComboBox>
            <Button Margin="15" Click="Save">Сохранить</Button>
        </StackPanel>
        <Grid Grid.Row="0" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label HorizontalAlignment="Center" FontSize="20" Grid.Row="0">Доступные теги</Label>
            <ListView ItemsSource="{Binding tagList, UpdateSourceTrigger=PropertyChanged}"
                      Margin="5"
                      Grid.Row="1"
                      HorizontalContentAlignment="Stretch"
                      >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock>
                                        <Run Text="ID: "/>
                                        <Run Text="{Binding Id}"/>
                                    </TextBlock>
                                    <TextBlock>
                                        <Run Text="Тег: #"/>
                                        <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Margin="5" VerticalAlignment="Center" DockPanel.Dock="Right" Click="AddTag">Применить</Button>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Label HorizontalAlignment="Center" FontSize="20" Grid.Row="0">Применённые теги</Label>
            <ListView ItemsSource="{Binding product.Tags, UpdateSourceTrigger=PropertyChanged}"
                      Margin="5"
                      Grid.Row="1"
                      HorizontalContentAlignment="Stretch"
                      >
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Border BorderBrush="Black" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock>
                                <Run Text="ID: "/>
                                <Run Text="{Binding Id}"/>
                                    </TextBlock>
                                    <TextBlock>
                                <Run Text="Тег: #"/>
                                <Run Text="{Binding Name}"/>
                                    </TextBlock>
                                </StackPanel>
                                <Button HorizontalAlignment="Right" Margin="5" VerticalAlignment="Center" DockPanel.Dock="Right" Click="RemoveTag">Убрать</Button>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>
