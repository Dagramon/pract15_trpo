<Page x:Class="pract15_trpo.Pages.MainPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:pract15_trpo.Pages"
      xmlns:converters="clr-namespace:pract15_trpo.Converters"
      mc:Ignorable="d" 
      xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
      d:DesignHeight="600" d:DesignWidth="1000"
      Title="Главная страница" Loaded="Page_Loaded">
    <Page.Resources>
        <converters:LessThanTenConverter x:Key="LessThanTenConverter"/>
        <converters:TagConverter x:Key="TagConverter"/>
    </Page.Resources>
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2">
            <Label>Поиск</Label>
            <TextBox materialDesign:HintAssist.Hint="Введите текст для поиска"
                     Text="{Binding searchQuery, UpdateSourceTrigger=PropertyChanged}"
                     TextChanged="Refresh"/>
        </StackPanel>
            <StackPanel Grid.Row="1" Grid.Column="0" Margin="5">
                <Label FontSize="16">Сортировка</Label>
            <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding selectedSortTag, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="Sort">
                <ComboBox.Items>
                        <ComboBoxItem Tag="Price">По цене</ComboBoxItem>
                        <ComboBoxItem Tag="Stock">По количеству</ComboBoxItem>
                </ComboBox.Items>
            </ComboBox>
                <StackPanel Orientation="Vertical">
                    <RadioButton IsChecked="True" x:Name="DescendingSort" Checked="Sort">По убыванию</RadioButton>
                    <RadioButton x:Name="AscendingSort" Checked="Sort">По возрастанию</RadioButton>
                </StackPanel>
                <Label>Фильтры</Label>
                <StackPanel>
                    <Label FontSize="16">Фильтр по цене</Label>
                    <Label>от</Label>
                    <TextBox Text="{Binding filterPriceFrom, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Введите цену" TextChanged="Refresh"/>
                    <Label>до</Label>
                    <TextBox Text="{Binding filterPriceTo, UpdateSourceTrigger=PropertyChanged}"
                             materialDesign:HintAssist.Hint="Введите цену" TextChanged="Refresh"/>
                <Label FontSize="16">По категории</Label>
                <ComboBox x:Name="CategoryComboBox" ItemsSource="{Binding CategoryService.Categories}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding categorySort, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="Refresh">
                </ComboBox>
                <Label FontSize="16">По бренду</Label>
                <ComboBox x:Name="BrandComboBox" ItemsSource="{Binding BrandService.Brands}" DisplayMemberPath="Name" SelectedValuePath="Name" SelectedValue="{Binding brandSort, UpdateSourceTrigger=PropertyChanged}" SelectionChanged="Refresh">
                </ComboBox>
                <TextBlock Text="{Binding ProductService.Products.Count, StringFormat={}Товаров в БД: {0}}"/>
                <TextBlock Text="{Binding ElementName=ProductList, Path=Items.Count, StringFormat={}Товаров в списке: {0}}"/>
                <Button Margin="5" Click="Reset">Сбросить</Button>
            </StackPanel>
        </StackPanel>
        <ListView Grid.Column="1" Grid.Row="1"
                  x:Name="ProductList" ItemsSource="{Binding ProductService.Products}"
                  HorizontalContentAlignment="Stretch"
                  SelectedItem="{Binding product}"
                  MouseDoubleClick="EditProduct"
                  >
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="BorderBrush" Value="Black"/>
                                <Setter Property="BorderThickness" Value="2"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Stock, Converter={StaticResource LessThanTenConverter}}" Value="True">
                                        <Setter Property="BorderBrush" Value="#ffd129"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Margin="5">
                            <Grid>
                                <TextBlock FontSize="16" Text="{Binding Name}" HorizontalAlignment="Left"></TextBlock>
                                <TextBlock FontSize="16" Text="{Binding Price, StringFormat={}{0:N2}$}" HorizontalAlignment="Right"></TextBlock>
                            </Grid>
                            <TextBlock>
                                <Run FontSize="20" Text="☆" Foreground="Gold"></Run>
                                <Run Text="{Binding Rating, StringFormat={}{0:N1}}"/>
                            </TextBlock>
                            <TextBlock Text="{Binding Category.Name}" Margin="0, 20, 0, 0"></TextBlock>
                            <Grid Margin="0, 20, 0, 0">
                                <TextBlock Text="{Binding Description}" HorizontalAlignment="Left"></TextBlock>
                                <TextBlock Text="{Binding Stock, StringFormat={}Остаток: {0}}" HorizontalAlignment="Right"></TextBlock>
                            </Grid>
                            <TextBlock Margin="0, 20, 0, 0" Text="{Binding Tags, Converter={StaticResource TagConverter}}"/>
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        <Grid x:Name="ManagerPanel" Visibility="Visible" Grid.Row="2" Grid.ColumnSpan="2" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal">
                <Button Margin="5" Click="AddProduct">Добавить товар</Button>
                <Button Margin="5" Click="RemoveProduct">Удалить товар</Button>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Margin="5" Click="GoCategories">Категории</Button>
                <Button Margin="5" Click="GoTags">Теги</Button>
                <Button Margin="5" Click="GoBrands">Бренды</Button>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
